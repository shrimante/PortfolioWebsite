---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import CTASection from '../components/CTASection.astro';
import CapabilityCard from '../components/CapabilityCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const pageTitle = "UAE MuleSoft Integration Hub Leader | Hybrid CloudHub 2.0 + RTF (OpenShift)";
const pageDescription = "Strategic MuleSoft leader in UAE specializing in Integration Hubs, CloudHub 2.0, and RTF on OpenShift. Driving API-led connectivity and hybrid cloud governance.";
const canonicalURL = new URL('/uae-integration-hub-mulesoft/', Astro.site || 'https://sriman.arch');

const faqs = [
  {
    question: "Do you have a valid UAE residency/visa status?",
    answer: "I am open to discussions regarding relocation, onsite requirements, and visa sponsorship for the right leadership opportunity within the UAE (Dubai/Abu Dhabi)."
  },
  {
    question: "What is your current notice period?",
    answer: "My standard notice period is typically 1-2 months, but I am open to discussing early release options for critical integration programs."
  },
  {
    question: "How do you handle NDA-restricted architectural projects?",
    answer: "I provide anonymized, NDA-safe case studies that demonstrate architectural patterns, scale, and business outcomes without disclosing proprietary client data or sensitive technical keys."
  },
  {
    question: "Are you available for frequent travel between Dubai and Abu Dhabi?",
    answer: "Yes, I am fully available for domestic travel across the Emirates as required for stakeholder alignment, workshop facilitation, and onsite delivery oversight."
  }
];

const capabilities = [
  {
    title: "Hybrid Deployment Strategy",
    description: "Expertise in CloudHub 2.0 and Runtime Fabric (RTF) on OpenShift, ensuring data residency compliance and performance.",
    icon: "cloud"
  },
  {
    title: "API-Led Connectivity",
    description: "Implementing 3-tier architecture (Experience, Process, System APIs) to maximize reuse and agility.",
    icon: "layers"
  },
  {
    title: "Enterprise Governance",
    description: "Establishing C4E models, automated quality gates, and standardized API lifecycle management.",
    icon: "shield"
  },
  {
    title: "Security & mTLS",
    description: "Hardening platforms with OAuth2, Mutual TLS, and secure connectivity to on-prem legacy systems.",
    icon: "shield"
  },
  {
    title: "Event-Driven Integration",
    description: "Leveraging Solace or Anypoint MQ for high-throughput, asynchronous event-driven architectures.",
    icon: "activity"
  },
  {
    title: "Observability Stack",
    description: "Structured logging and monitoring using Splunk, ELK, and Anypoint Monitoring for sub-second MTTR.",
    icon: "activity"
  }
];

// Schema.org JSON-LD
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "name": siteConfig.name,
      "jobTitle": "Integration & Platform Engineering (MuleSoft)",
      "url": Astro.site,
      "sameAs": [
        siteConfig.linkedIn
      ],
      "areaServed": {
        "@type": "Country",
        "name": "United Arab Emirates"
      }
    },
    {
      "@type": "ProfessionalService",
      "name": "Integration Architecture / MuleSoft Delivery",
      "description": pageDescription,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dubai",
        "addressCountry": "AE"
      }
    },
    {
      "@type": "WebPage",
      "@id": canonicalURL,
      "url": canonicalURL,
      "name": pageTitle,
      "description": pageDescription
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <article class="pt-32 pb-24">
    <!-- Hero Section -->
    <header class="container mx-auto px-6 mb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 mb-8 text-[10px] font-bold tracking-[0.2em] text-accent uppercase bg-accent/5 rounded-full border border-accent/10">
          Strategic Integration Leadership
        </div>
        <h1 class="text-5xl md:text-7xl font-bold text-slate-900 tracking-tighter mb-8 italic leading-tight">
          UAE MuleSoft <br/>
          <span class="text-accent underline decoration-slate-200">Integration Hub</span> Leader
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed max-w-2xl mb-12 font-outfit">
          Specializing in hybrid ecosystems (CloudHub 2.0 + RTF on OpenShift) for regulated UAE industries. I bridge the gap between enterprise architecture and high-velocity delivery.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="px-8 py-4 bg-accent text-white font-bold rounded-xl hover:bg-accent-muted transition-all shadow-xl shadow-accent/20 text-xs uppercase tracking-widest text-center">
            Inquire for UAE Roles
          </a>
          <a href={siteConfig.resumePath} class="px-8 py-4 bg-white text-slate-900 font-bold rounded-xl hover:shadow-lg transition-all border border-slate-200 text-xs uppercase tracking-widest text-center" download>
            Download PDF Narrative
          </a>
        </div>
      </div>
    </header>

    <!-- What I do section -->
    <section class="bg-white py-24">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic">
          What I Deliver
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-accent">Platform Consolidation</h3>
            <p class="text-slate-600 text-lg leading-relaxed font-outfit">
              Consolidating fragmented integration points into a unified, high-availability platform that drives reuse and reduces operational overhead.
            </p>
          </div>
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-accent">Strategic C4E Setup</h3>
            <p class="text-slate-600 text-lg leading-relaxed font-outfit">
              Moving beyond point-to-point integration by establishing a Center for Enablement that empowers distributed delivery squads with standardized assets.
            </p>
          </div>
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-accent">Zero-Trust Hybrid Connectivity</h3>
            <p class="text-slate-600 text-lg leading-relaxed font-outfit">
              Bridging modern cloud-native applications with legacy on-prem systems using secure, high-performance hybrid deployment models (RTF).
            </p>
          </div>
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-accent">Compliance-First Governance</h3>
            <p class="text-slate-600 text-lg leading-relaxed font-outfit">
              Enforcing security standards and data localization requirements at the platform level, ensuring consistent compliance across every API.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- UAE Specific section -->
    <section class="py-24 bg-slate-50 border-y border-slate-200">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic">
          Solving UAE-Specific Integration Realities
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="p-6">
            <h3 class="text-lg font-bold mb-4">Hybrid Residency</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Implementing RTF on OpenShift for workloads that MUST remain within client-private data centers for local compliance.</p>
          </div>
          <div class="p-6 border-l border-slate-200">
            <h3 class="text-lg font-bold mb-4">Regulated Ecosystems</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Designing integration flows that adhere to NESA and UAE Central Bank security standards by default.</p>
          </div>
          <div class="p-6 border-l border-slate-200">
            <h3 class="text-lg font-bold mb-4">Private Connectivity</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Expertise in Anypoint VPN, VPC Peering, and Transit Gateway for secure connectivity between UAE cloud regions.</p>
          </div>
          <div class="p-6 border-l border-slate-200">
            <h3 class="text-lg font-bold mb-4">Scale & Performance</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Building platforms that scale to millions of members, optimized for the high-demand digital growth in Dubai and Abu Dhabi.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Capabilities Grid -->
    <section class="py-24">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic">
          Core Capabilities
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {capabilities.map(cap => (
            <CapabilityCard {...cap} />
          ))}
        </div>
      </div>
    </section>

    <!-- Outcomes / Proof -->
    <section class="py-24 bg-slate-900 text-white overflow-hidden relative">
       <div class="container mx-auto px-6 relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold mb-16 tracking-tighter italic">
          High-Level Strategic Outcomes
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <div class="text-5xl font-bold text-accent mb-4 tracking-tighter italic">40% Faster</div>
            <p class="text-slate-400 text-lg">Average improvement in PI velocity by slashing integration bottleneck cycles through meaningful reuse.</p>
          </div>
          <div>
            <div class="text-5xl font-bold text-accent mb-4 tracking-tighter italic">$250K+ Saved</div>
            <p class="text-slate-400 text-lg">Annual operational cost reductions by modernizing integration stacks and retiring redundant legacy licenses.</p>
          </div>
          <div>
            <div class="text-5xl font-bold text-accent mb-4 tracking-tighter italic text-nowrap">120+ APIs</div>
            <p class="text-slate-400 text-lg">Successfully governing and scaling 120+ production APIs with zero major security incidents in regulated sectors.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- NDA-safe case studies -->
    <section class="py-24">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic">
          NDA-Safe Case Study Briefs
        </h2>
        <div class="space-y-12">
          <div class="glass p-10 border-l-4 border-accent">
            <h3 class="text-2xl font-bold mb-4">National-Scale Integration Hub Modernization</h3>
            <p class="text-slate-600 text-lg leading-relaxed mb-6 font-outfit">
              Architectured the transition from fragmented integration layers to a unified MuleSoft Integration Hub. Implemented a hybrid model using RTF on OpenShift to satisfy data residency laws while leveraging CloudHub for elastic demand.
            </p>
            <ul class="flex flex-wrap gap-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">
              <li class="bg-slate-50 px-3 py-1 rounded border border-slate-200">Hybrid RTF</li>
              <li class="bg-slate-50 px-3 py-1 rounded border border-slate-200">Data Residency</li>
              <li class="bg-slate-50 px-3 py-1 rounded border border-slate-200">Scale</li>
            </ul>
          </div>
          <div class="glass p-10 border-l-4 border-accent">
            <h3 class="text-2xl font-bold mb-4">Secure On-Prem Connectivity for Regulated Finance</h3>
            <p class="text-slate-600 text-lg leading-relaxed mb-6 font-outfit">
              Established a secure API gateway layer for a legacy banking estate. Implemented Mutual TLS and OAuth2 policies alongside Transit Gateway connectivity to bridge private banking cores with modern mobile experience layers.
            </p>
            <ul class="flex flex-wrap gap-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">
              <li class="bg-slate-50 px-3 py-1 rounded border border-slate-200">Security (mTLS)</li>
              <li class="bg-slate-50 px-3 py-1 rounded border border-slate-200">FinTech Integration</li>
              <li class="bg-slate-50 px-3 py-1 rounded border border-slate-200">VPC Peering</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 30/60/90 Section -->
    <section class="py-24 bg-slate-50">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic">
          Delivery Roadmap: First 90 Days
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="glass p-8 bg-white">
            <div class="text-accent font-bold text-7xl mb-6 opacity-20 italic">30</div>
            <h3 class="text-xl font-bold mb-4">Assessment & Quick Wins</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Full audit of the integration estate, identification of critical performance bottlenecks, and implementation of immediate security hardening measures.</p>
          </div>
          <div class="glass p-8 bg-white">
             <div class="text-accent font-bold text-7xl mb-6 opacity-20 italic">60</div>
            <h3 class="text-xl font-bold mb-4">Standards & C4E Setup</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Establishment of the C4E operating model, publication of 'Gold Standard' templates, and alignment of CI/CD pipelines with quality gates.</p>
          </div>
          <div class="glass p-8 bg-white">
             <div class="text-accent font-bold text-7xl mb-6 opacity-20 italic">90</div>
            <h3 class="text-xl font-bold mb-4">Scalable Momentum</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Full operationalization of the Integration Hub. Shifting the focus to self-service discovery and scaling the API ecosystem across all business units.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Engagement models -->
    <section class="py-24">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic">
          Engagement Models
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-center">
          <div class="p-12 glass border-t-8 border-t-accent shadow-lg">
            <h3 class="text-2xl font-bold mb-4">Permanent Leadership</h3>
            <p class="text-slate-600 mb-8 font-outfit">Driving long-term integration strategy as an Associate Director or Integration Hub Lead within your organization.</p>
            <div class="text-xs font-bold uppercase tracking-widest text-slate-400">Dubai / Abu Dhabi / Remote</div>
          </div>
          <div class="p-12 glass border-t-8 border-t-slate-900 shadow-lg">
            <h3 class="text-2xl font-bold mb-4">Strategic Consulting</h3>
            <p class="text-slate-600 mb-8 font-outfit">Advisory engagement focused on platform setup, migration strategy, or establishing integration governance standards.</p>
            <div class="text-xs font-bold uppercase tracking-widest text-slate-400">Fixed Term / Project Based</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQs -->
    <section class="py-24 bg-slate-50">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16 tracking-tighter italic text-center">
          Frequently Asked Questions (Recruiters)
        </h2>
        <FAQAccordion items={faqs} />
      </div>
    </section>

    <!-- Lead Capture Form -->
    <section id="contact" class="py-24">
      <div class="container mx-auto px-6 max-w-4xl">
        <div class="glass p-12 md:p-16 border border-slate-200">
          <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-8 tracking-tighter italic text-center">
            Start a Conversation
          </h2>
          <p class="text-center text-slate-500 mb-12 font-outfit">
            Inquire about current leadership vacancies in the UAE or request a detailed technical brief.
          </p>

          <form action="/api/contact" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="name" class="text-xs font-bold uppercase tracking-widest text-slate-500">Full Name</label>
                <input type="text" id="name" name="name" required class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all" />
              </div>
              <div class="space-y-2">
                <label for="company" class="text-xs font-bold uppercase tracking-widest text-slate-500">Company / Recruitment Agency</label>
                <input type="text" id="company" name="company" required class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all" />
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="email" class="text-xs font-bold uppercase tracking-widest text-slate-500">Professional Email</label>
                <input type="email" id="email" name="email" required class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all" />
              </div>
              <div class="space-y-2">
                <label for="location" class="text-xs font-bold uppercase tracking-widest text-slate-500">Target Location</label>
                <select id="location" name="location" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 transition-all">
                  <option value="Dubai">Dubai</option>
                  <option value="Abu Dhabi">Abu Dhabi</option>
                  <option value="Remote (UAE Focus)">Remote (UAE Focus)</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <div class="space-y-2">
              <label for="message" class="text-xs font-bold uppercase tracking-widest text-slate-500">Inquiry Details</label>
              <textarea id="message" name="message" rows="5" required class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all" placeholder="Tell me about the role or the architectural challenge..."></textarea>
            </div>

            <button type="submit" class="w-full py-4 bg-accent text-white font-bold rounded-xl hover:bg-accent-muted transition-all shadow-xl shadow-accent/20 text-xs uppercase tracking-widest">
              Send Leadership Inquiry
            </button>
            <p class="text-center text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-4">
              Or email directly: <a href={`mailto:${siteConfig.email}`} class="text-accent underline">{siteConfig.email}</a>
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <CTASection 
      title="Scale Your Integration Program"
      subtitle="Seeking an Integration Hub leader to drive your 2024–2025 digital transformation in the UAE?"
      primaryCTA={{ text: "Book 15-min intro", link: "https://calendly.com/sriman-arch/15min" }}
      secondaryCTA={{ text: "Connect on LinkedIn", link: siteConfig.linkedIn }}
    />

  </article>

</BaseLayout>


