---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const accelerators = siteConfig.accelerators || [];

export const prerender = true;
---

<BaseLayout 
  title="Engineering Accelerators | Sriman Tirupathy Eshwarappa"
  description="A collection of 18+ production-ready engineering accelerators designed to automate the integration lifecycle."
>
  <article class="pt-32 pb-24">
    <div class="container mx-auto px-6">
      
      <!-- Header -->
      <header class="max-w-4xl mb-12 text-center mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 mb-8 text-[10px] font-bold tracking-[0.2em] text-accent uppercase bg-accent/5 rounded-full border border-accent/10">
          Open Source & Automation
        </div>
        <h1 class="text-4xl md:text-7xl font-bold text-slate-900 tracking-tighter mb-8 italic">
          Engineering Accelerators
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed max-w-2xl mx-auto">
          I maintain a modular ecosystem of assets designed to eliminate redundant work and enforce architectural standards across high-stakes integration programs.
        </p>
      </header>

      <!-- Search & Filters Toolbar -->
      <div class="glass p-4 rounded-2xl mb-12 flex flex-col md:flex-row gap-4 items-center justify-between border border-slate-200 bg-white/50 sticky top-24 z-10">
        <div class="relative w-full md:w-96">
          <input 
            type="text" 
            id="acceleratorSearch" 
            placeholder="Search by title, technology, or impact..." 
            class="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-accent/20 focus:border-accent outline-none transition-all"
          />
          <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
        </div>

        <div class="flex items-center gap-4 w-full md:w-auto">
          <select 
            id="acceleratorSort" 
            class="bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-xs font-bold uppercase tracking-widest text-slate-600 outline-none focus:ring-2 focus:ring-accent/20 transition-all flex-grow md:flex-grow-0"
          >
            <option value="default">Sort by: Default</option>
            <option value="title">Sort by: A-Z</option>
            <option value="impact">Sort by: Impact Scope</option>
          </select>

          <div class="flex bg-slate-100 p-1 rounded-xl border border-slate-200">
            <button 
              id="gridViewBtn" 
              class="p-2 rounded-lg bg-white shadow-sm text-accent transition-all"
              title="Grid View"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </button>
            <button 
              id="listViewBtn" 
              class="p-2 rounded-lg text-slate-400 hover:text-slate-600 transition-all"
              title="List View"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Grid / Container -->
      <div id="acceleratorGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 transition-all duration-500">
        {accelerators.map((acc) => (
          <div 
            class="accelerator-card group glass p-8 rounded-[32px] border border-slate-200 bg-white/50 hover:bg-white hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col h-full relative overflow-hidden"
            data-title={acc.title}
            data-impact={acc.impact}
            data-tags={acc.tags.join(', ')}
          >
            <!-- Decorative Background Element -->
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-accent/5 rounded-full blur-2xl group-hover:bg-accent/10 transition-colors"></div>
            
            <div class="flex items-center justify-between mb-8 card-header">
              <div class="w-12 h-12 rounded-2xl bg-slate-900 flex items-center justify-center text-white group-hover:bg-accent transition-all duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path></svg>
              </div>
              <div class="flex gap-2 tags-container">
                {acc.tags.slice(0, 2).map((tag) => (
                  <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400 border border-slate-100 px-2 py-1 rounded-md">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <h3 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-accent transition-colors tracking-tight italic card-title">
              {acc.title}
            </h3>
            
            <p class="text-slate-500 text-sm leading-relaxed mb-8 flex-grow card-description">
              {acc.description}
            </p>

            <div class="pt-6 border-t border-slate-100 mt-auto card-footer">
              <div class="flex flex-col gap-4">
                <div class="impact-section">
                  <div class="text-[9px] font-bold uppercase tracking-widest text-accent mb-1">Architecture Impact</div>
                  <p class="text-[11px] text-slate-600 font-medium leading-normal italic">{acc.impact}</p>
                </div>
                
                <a 
                  href={`https://github.com/shrimante/${acc.repo}`} 
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-between w-full p-3 bg-slate-50 rounded-xl group-hover:bg-accent group-hover:text-white transition-all duration-300 shadow-sm"
                >
                  <span class="text-[10px] font-bold uppercase tracking-widest">View Source Code</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- No Results State -->
      <div id="noResults" class="hidden py-24 text-center">
        <div class="text-slate-300 mb-6 flex justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-2">No accelerators found</h3>
        <p class="text-slate-500">Try adjusting your search terms or filters.</p>
      </div>

      <!-- Footer CTA -->
      <div class="mt-32 text-center p-16 glass rounded-[48px] border border-slate-200">
        <h2 class="text-3xl font-bold text-slate-900 mb-6 tracking-tighter italic">Enterprise Standardized Delivery</h2>
        <p class="text-slate-600 max-w-2xl mx-auto mb-10 text-lg">
          These assets form the backbone of a modern Integration Center of Excellence (ICoE), ensuring that every API built is secure, resilient, and governed by default.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 bg-slate-900 text-white hover:bg-accent text-xs uppercase font-bold tracking-widest rounded-full transition-all shadow-xl hover:shadow-accent/20">
          Request Technical Implementation
        </a>
      </div>

    </div>
  </article>

  <style is:global>
    /* List View Styles */
    .list-view {
      display: flex !important;
      flex-direction: column !important;
      gap: 1.5rem !important;
    }

    .list-view .accelerator-card {
      flex-direction: row !important;
      align-items: center !important;
      padding: 1.5rem 2rem !important;
      border-radius: 24px !important;
      gap: 2rem !important;
    }

    .list-view .card-header {
      margin-bottom: 0 !important;
      flex-shrink: 0 !important;
    }

    .list-view .tags-container {
      display: none !important;
    }

    .list-view .card-title {
      margin-bottom: 0 !important;
      width: 250px !important;
      flex-shrink: 0 !important;
      font-size: 1.125rem !important;
    }

    .list-view .card-description {
      margin-bottom: 0 !important;
      font-size: 0.875rem !important;
      line-height: normal !important;
    }

    .list-view .card-footer {
      border-top: none !important;
      margin-top: 0 !important;
      padding-top: 0 !important;
      width: 320px !important;
      flex-shrink: 0 !important;
    }

    .list-view .impact-section {
      display: none !important;
    }

    @media (max-width: 1024px) {
      .list-view .accelerator-card {
        flex-direction: column !important;
        align-items: flex-start !important;
      }
      .list-view .card-title, .list-view .card-footer {
        width: 100% !important;
      }
    }
  </style>

  <script is:inline>
    // Interactivity Logic
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('acceleratorSearch');
      const sortSelect = document.getElementById('acceleratorSort');
      const gridBtn = document.getElementById('gridViewBtn');
      const listBtn = document.getElementById('listViewBtn');
      const gridContainer = document.getElementById('acceleratorGrid');
      const noResults = document.getElementById('noResults');
      const cards = Array.from(document.querySelectorAll('.accelerator-card'));

      // 1. Search Logic
      const filterCards = () => {
        const query = searchInput.value.toLowerCase();
        let visibleCount = 0;

        cards.forEach(card => {
          const title = card.dataset.title.toLowerCase();
          const impact = card.dataset.impact.toLowerCase();
          const tags = card.dataset.tags.toLowerCase();
          
          if (title.includes(query) || impact.includes(query) || tags.includes(query)) {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            card.classList.add('hidden');
          }
        });

        noResults.classList.toggle('hidden', visibleCount > 0);
        gridContainer.classList.toggle('hidden', visibleCount === 0);
      };

      searchInput.addEventListener('input', filterCards);

      // 2. Sort Logic
      sortSelect.addEventListener('change', () => {
        const val = sortSelect.value;
        const sortedCards = [...cards];

        if (val === 'title') {
          sortedCards.sort((a, b) => a.dataset.title.localeCompare(b.dataset.title));
        } else if (val === 'impact') {
          sortedCards.sort((a, b) => a.dataset.impact.length - b.dataset.impact.length);
        } else {
          // Default order (assuming original DOM order)
          // For simplicity, we just rely on the original sequence if 'default'
          // In a more complex app we'd store initial indices
        }

        sortedCards.forEach(card => gridContainer.appendChild(card));
      });

      // 3. View Switcher
      const setView = (view) => {
        if (view === 'list') {
          gridContainer.classList.add('list-view');
          gridContainer.classList.remove('grid-cols-1', 'md:grid-cols-2', 'lg:grid-cols-3');
          listBtn.classList.add('bg-white', 'shadow-sm', 'text-accent');
          listBtn.classList.remove('text-slate-400');
          gridBtn.classList.remove('bg-white', 'shadow-sm', 'text-accent');
          gridBtn.classList.add('text-slate-400');
        } else {
          gridContainer.classList.remove('list-view');
          gridContainer.classList.add('grid-cols-1', 'md:grid-cols-2', 'lg:grid-cols-3');
          gridBtn.classList.add('bg-white', 'shadow-sm', 'text-accent');
          gridBtn.classList.remove('text-slate-400');
          listBtn.classList.remove('bg-white', 'shadow-sm', 'text-accent');
          listBtn.classList.add('text-slate-400');
        }
      };

      gridBtn.addEventListener('click', () => setView('grid'));
      listBtn.addEventListener('click', () => setView('list'));
    });
  </script>
    </div>
  </article>
</BaseLayout>
