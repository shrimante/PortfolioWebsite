---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfigAr } from '../../config/site-ar';

const config = siteConfigAr;

export const prerender = true;
---

<BaseLayout title="حول | سريمان تيروباثي إيشوارابا">
	<section class="container mx-auto px-6 py-24">
		<div class="flex flex-col lg:flex-row gap-16 items-start">
			<div class="lg:w-2/3">
				<h1 class="text-4xl font-bold text-slate-900 mb-8 text-right">البيان <span class="text-gradient">المعماري</span></h1>
				<p class="text-lg text-slate-700 mb-6 leading-relaxed italic border-r-2 border-accent/40 pr-6 bg-accent/5 py-4 rounded-l-lg text-right">
					"الهندسة المعمارية لا تتعلق برسم الصناديق؛ بل تتعلق بإدارة القصور الذاتي للأعمال المتنامية من خلال الحكمة التقنية."
				</p>
				<div class="space-y-6 text-slate-600 leading-relaxed text-right">
					<p>
						لأكثر من عقدين من الزمن، عملت في نقطة التقاء استراتيجية الأعمال والتميز الهندسي. بصفتي رئيس مهندسين معماريين (Principal Architect)، فإن مهمتي هي ضمان ألا تكون التكنولوجيا أبدًا عائقًا أمام الابتكار. 
					</p>
					<p>
						سواء كان ذلك من خلال تقديم طبقة الهوية للنظام البيئي الوطني الهندي (**Aadhaar/UIDAI**) أو تنسيق مراكز التكامل العالمية باستخدام **MuleSoft** و **Solace**، يظل تركيزي على **Scalability** و **Security** و **Speed**.
					</p>
					<p>
						حدودي الحالية هي المؤسسة الوكيل (**Agentic Enterprise**). أنا رائد في تدفقات العمل التي تستفيد من **LLMs** ليس فقط لإكمال الكود، ولكن للاستدلال المعماري رفيع المستوى، وهندسة الجودة المؤتمتة، وتسريع التسليم.
					</p>
				</div>
				
				<h2 class="text-2xl font-bold text-slate-900 mt-12 mb-6 text-right">مبادئ القيادة</h2>
				<div class="space-y-4">
					<div class="p-6 glass rounded-2xl border border-slate-200 group hover:border-accent/40 transition-all shadow-sm text-right">
						<h3 class="text-accent font-semibold mb-2 flex items-center justify-start flex-row-reverse gap-2">
							<span class="w-2 h-2 rounded-full bg-accent"></span>
							الراديكالية البراغماتية (Pragmatic Radicalism)
						</h3>
						<p class="text-slate-600">احترام الأنظمة القديمة (**Legacy Systems**) التي تدير الأعمال، ولكن تحديث أي مكون يعيق المرونة بلا رحمة.</p>
					</div>
					<div class="p-6 glass rounded-2xl border border-slate-200 group hover:border-accent/40 transition-all shadow-sm text-right">
						<h3 class="text-accent font-semibold mb-2 flex items-center justify-start flex-row-reverse gap-2">
							<span class="w-2 h-2 rounded-full bg-accent"></span>
							دورة الحياة المعززة بالذكاء الاصطناعي (The AI-Augmented Lifecycle)
						</h3>
						<p class="text-slate-600">الانتقال إلى ما هو أبعد من ضمان الجودة (**QA**) اليدوي نحو هندسة جودة ذكية وذاتية المعالجة مدعومة بـ **GenAI** والمراقبة الدلالية (**Semantic Observability**).</p>
					</div>
				</div>
			</div>

			{config.headshot?.enabled && (
				<div class="lg:w-1/3 w-full order-first lg:order-last">
					<div class="glass p-2 rounded-[2.5rem] sticky top-32 shadow-sm border border-slate-200">
						<div class="aspect-square rounded-[2rem] overflow-hidden bg-slate-100">
							<img 
								src={config.headshot.src} 
								alt={config.headshot.alt} 
								class="w-full h-full object-cover filter grayscale"
							/>
						</div>
						<div class="p-6 text-center">
							<div class="text-slate-900 font-bold mb-1">سريمان ت. إ.</div>
							<div class="text-[10px] uppercase font-bold tracking-widest text-slate-500">Associate Director – Integrations</div>
						</div>
					</div>
				</div>
			)}
		</div>
	</section>
</BaseLayout>
