---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export const prerender = true;

const title = "حقيبة أدوات بدء برنامج API في MuleSoft";
const description = "أساس مشروع Mule 4 الموحد مع معايير المؤسسة المضمنة.";
const githubRepo = "https://github.com/shrimante/mulesoft-api-program-starter-kit";
---

<BaseLayout 
  title={`${title} | المسرعات الهندسية`}
  description={description}
>
  <article class="pt-32 pb-24" dir="rtl">
    <div class="container mx-auto px-6 max-w-4xl">
      
      <!-- Back Link -->
      <a href="/ar/accelerators" class="inline-flex items-center gap-2 text-slate-500 hover:text-accent transition-colors mb-12 group text-sm font-bold uppercase tracking-widest">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform rotate-180"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        العودة إلى المسرعات
      </a>

      <!-- Header -->
      <header class="mb-16 relative">
        <div class="absolute -right-8 -top-8 w-32 h-32 bg-accent/5 rounded-full blur-3xl -z-10"></div>
        <div class="inline-flex items-center gap-2 px-4 py-2 mb-6 text-[10px] font-bold tracking-[0.2em] text-accent uppercase bg-accent/5 rounded-full border border-accent/10">
          مسرع التسليم
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tighter mb-6 italic">
          {title}
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed mb-8">
          أساس محكوم وجاهز للإنتاج لبرامج Mule 4 API يدمج معايير المراقبة ومعالجة الأخطاء في المؤسسة في كل مشروع جديد.
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href={githubRepo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white hover:bg-accent text-xs uppercase font-bold tracking-widest rounded-xl transition-all shadow-xl hover:shadow-accent/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            عرض المستودع
          </a>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-slate prose-lg max-w-none">
        
        <div class="glass p-8 rounded-3xl mb-12 border border-slate-200 bg-white/50">
          <h2 class="text-2xl font-bold text-slate-900 mb-4 tracking-tight italic">1. القضاء على فوضى البدء</h2>
          <p class="text-slate-600 mb-4">
            غالبًا ما تعاني مشاريع MuleSoft الجديدة من هياكل مشاريع غير متسقة، واستراتيجيات تحميل خصائص مجزأة، ومراقبة مخصصة. تقضي حقيبة أدوات البدء هذه على "فوضى البدء" من خلال توفير أساس محكوم وموجه يدمج معايير هندسة المؤسسة من اليوم الأول.
          </p>
        </div>

        <div class="glass p-8 rounded-3xl mb-12 border border-slate-200 bg-white/50">
          <h2 class="text-2xl font-bold text-slate-900 mb-4 tracking-tight italic">2. التبعيات الأساسية الإلزامية</h2>
          <p class="text-slate-600 mb-6">على عكس القوالب العامة، تدمج حقيبة أدوات البدء هذه المسرعات السابقة كتبعيات أساسية إلزامية:</p>
          <ul class="space-y-4 text-slate-600">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span><strong>معيار المراقبة:</strong> جميع التدفقات معدة مسبقًا باستخدام <code>mulesoft-logging-correlation-standard</code>، مما يضمن تتبع الارتباط الموحد وتسجيل JSON المنظم من البداية.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span><strong>إطار عمل الخطأ الأساسي:</strong> يتم استيراد <code>mulesoft-error-handling-standard</code> كاستراتيجية عالمية افتراضية، مما يضمن التزام كل استجابة API بنموذج المؤسسة الأساسي.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span><strong>استراتيجية خصائص البيئة:</strong> تحميل موحد للبيئات المحلية والتطوير والاختبار والإنتاج، بما في ذلك تأمين الخصائص عبر تشفير AES-256.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span><strong>MUnit الأساسي:</strong> مجموعة اختبارات مهيأة مسبقًا تتحقق من انتشار الارتباط وتعيين الأخطاء، مما يضمن عمليات نشر عالية الجودة.</span>
            </li>
          </ul>
        </div>

        <div class="glass p-8 rounded-3xl mb-12 border border-slate-200 bg-slate-900 text-white relative overflow-hidden">
          <div class="absolute left-0 top-0 w-64 h-64 bg-accent/20 rounded-full blur-3xl"></div>
          <h2 class="text-2xl font-bold mb-6 tracking-tight italic relative z-10">قائمة مراجعة الحوكمة</h2>
          
          <div class="relative z-10 space-y-6 text-slate-300">
            <p>يجب أن يلتزم كل API يتم تسليمه عبر حقيبة أدوات البدء هذه بـ <strong>تعريف الإنجاز (DoD)</strong>:</p>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm font-mono mt-4">
              <li class="bg-white/5 p-3 rounded border border-white/10 text-slate-300 whitespace-nowrap">✓ دمج التسجيل المعياري</li>
              <li class="bg-white/5 p-3 rounded border border-white/10 text-slate-300 whitespace-nowrap">✓ ربط معالجة الأخطاء الأساسية</li>
              <li class="bg-white/5 p-3 rounded border border-white/10 text-slate-300 whitespace-nowrap">✓ تتبع معرف الارتباط</li>
              <li class="bg-white/5 p-3 rounded border border-white/10 text-slate-300 whitespace-nowrap">✓ تأمين خصائص الخزنة</li>
              <li class="bg-white/5 p-3 rounded border border-white/10 text-slate-300 whitespace-nowrap">✓ تغطية كود MUnit بنسبة 80%+</li>
              <li class="bg-white/5 p-3 rounded border border-white/10 text-slate-300 whitespace-nowrap">✓ تصميم واعٍ بالطبقة (S/P/E)</li>
            </ul>
          </div>
        </div>

        <div class="glass p-8 rounded-3xl mb-12 border border-slate-200 bg-white/50">
          <h2 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight italic" dir="ltr">Standardized POM Structure</h2>
          <p class="text-slate-600 mb-4">يفرض ملف <code>pom.xml</code> استهلاك مسرعات الهندسة المشتركة، مما يضمن أن فرق التسليم تقضي وقتها في منطق العمل بدلاً من أسلاك إطار العمل.</p>
          
          <div class="bg-slate-900 rounded-xl p-6 overflow-x-auto" dir="ltr">
<pre><code class="text-sm text-green-400 font-mono">{"<"}dependency{">"}
  {"<"}groupId{">"}com.enterprise.architecture{"</"}groupId{">"}
  {"<"}artifactId{">"}mulesoft-logging-correlation-standard{"</"}artifactId{">"}
  {"<"}version{">"}1.0.0{"</"}version{">"}
  {"<"}classifier{">"}mule-plugin{"</"}classifier{">"}
{"</"}dependency{">"}

{"<"}dependency{">"}
  {"<"}groupId{">"}com.enterprise.architecture{"</"}groupId{">"}
  {"<"}artifactId{">"}mulesoft-error-handling-standard{"</"}artifactId{">"}
  {"<"}version{">"}1.0.0{"</"}version{">"}
  {"<"}classifier{">"}mule-plugin{"</"}classifier{">"}
{"</"}dependency{">"}</code></pre>
          </div>
        </div>

      </div>

      <!-- Footer CTA -->
      <div class="mt-16 text-center">
        <a href={githubRepo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 bg-slate-100 text-slate-900 hover:bg-slate-200 text-sm uppercase font-bold tracking-widest rounded-xl transition-all font-mono">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          استكشف حقيبة أدوات البدء الكاملة على GitHub
        </a>
      </div>

    </div>
  </article>
</BaseLayout>
