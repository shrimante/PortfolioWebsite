import BaseLayout from '../../../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="نموذج أمن MuleSoft | سريمان تيروباثي إيشوارابا">
  <div class="container mx-auto px-6 py-24 text-right">
    <div class="mb-12">
      <a href="/ar/#case-studies" class="text-accent hover:text-slate-900 transition-colors text-sm uppercase tracking-widest font-bold mb-8 inline-block flex items-center flex-row-reverse gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-180"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        الرجوع إلى الملف الشخصي
      </a>
      <h1 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tighter">نموذج أمن MuleSoft</h1>
      <p class="text-slate-600 max-w-2xl text-lg">
        بنية أمنية شاملة توضح تدفق OAuth2 Client Credentials، وفرض JWT عند بوابة الـ API، والتحكم في الوصول القائم على الأدوار (RBAC) الذي يربط مستخدمي منصة Anypoint بصلاحيات دقيقة.
      </p>
    </div>

    <div class="mb-4">
      <div class="glass p-2 md:p-6 rounded-[2.5rem] bg-slate-50/50 overflow-hidden group cursor-zoom-in" data-zoom-trigger>
        <div class="relative overflow-hidden rounded-[2rem]">
          <img 
            src="/images/gallery_thumbnail_2.png" 
            alt="MuleSoft Security Model" 
            class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
            data-gsap="reveal"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Image Zoom Overlay -->
  <div id="zoom-overlay" class="fixed inset-0 z-[100] bg-slate-900/98 backdrop-blur-2xl hidden flex items-center justify-center cursor-zoom-out p-4 md:p-12 transition-all duration-500">
      <div class="relative w-full h-full flex items-center justify-center">
          <img id="zoom-image" src="" alt="Zoomed Diagram" class="max-w-full max-h-full object-contain rounded-xl shadow-2xl border border-white/10" />
          <button id="close-zoom" class="absolute top-4 right-4 md:top-8 md:right-8 p-3 bg-white/10 hover:bg-white/20 hover:scale-110 active:scale-90 rounded-full text-white transition-all duration-300" aria-label="Close zoom">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
          
          <div class="absolute bottom-8 left-1/2 -translate-x-1/2 bg-white/10 backdrop-blur-md px-6 py-2 rounded-full border border-white/20 text-white/70 text-[10px] font-bold uppercase tracking-widest pointer-events-none">
            انقر في أي مكان للإغلاق
          </div>
      </div>
  </div>

  <script>
      import { gsap } from 'gsap';

      document.addEventListener('DOMContentLoaded', () => {
          const trigger = document.querySelector('[data-zoom-trigger]');
          const overlay = document.getElementById('zoom-overlay');
          const zoomImg = document.getElementById('zoom-image') as HTMLImageElement;
          const closeBtn = document.getElementById('close-zoom');

          if (!trigger || !overlay || !zoomImg) return;

          trigger.addEventListener('click', () => {
              const img = trigger.querySelector('img');
              if (!img) return;
              
              zoomImg.src = img.src;
              
              overlay.classList.remove('hidden');
              
              // GSAP Animation for premium feel
              gsap.fromTo(overlay, 
                  { opacity: 0 }, 
                  { opacity: 1, duration: 0.5, ease: "power3.out" }
              );
              
              gsap.fromTo(zoomImg, 
                  { scale: 0.9, opacity: 0, y: 20 }, 
                  { scale: 1, opacity: 1, y: 0, duration: 0.7, ease: "expo.out", delay: 0.1 }
              );
              
              document.body.style.overflow = 'hidden'; // Prevent background scroll
          });

          const closeZoom = () => {
              gsap.to(overlay, { 
                  opacity: 0, 
                  duration: 0.4, 
                  ease: "power3.inOut",
                  onComplete: () => {
                      overlay.classList.add('hidden');
                      document.body.style.overflow = '';
                  }
              });
          };

          overlay.addEventListener('click', closeZoom);
          closeBtn?.addEventListener('click', (e) => {
              e.stopPropagation();
              closeZoom();
          });
          
          // Escape key to close
          document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
                  closeZoom();
              }
          });
      });
  </script>
</BaseLayout>
