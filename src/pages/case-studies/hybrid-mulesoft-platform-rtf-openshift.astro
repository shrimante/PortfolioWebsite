---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site';

export const prerender = true;

const title = "Hybrid MuleSoft Platform: RTF on OpenShift";
const teaser = "Architected a 'best-of-both-worlds' hybrid platform balancing CloudHub 2.0 for elastic scale and Runtime Fabric (RTF) on OpenShift for internal datacenter locality and compliance.";
---

<BaseLayout title={`${title} | Sriman Tirupathy Eshwarappa`}>
  <article class="pt-32 pb-24">
    <div class="container mx-auto px-6 max-w-5xl">
      <a href="/#case-studies" class="inline-flex items-center gap-2 text-accent text-[10px] uppercase font-bold tracking-widest mb-12 hover:translate-x-[-4px] transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Back to Case Studies
      </a>

      <header class="mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-[10px] font-bold tracking-widest text-accent uppercase bg-accent/5 rounded-full border border-accent/10">
          Reference Architecture
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-slate-900 mb-8 leading-tight tracking-tighter italic">{title}</h1>
        <p class="text-xl text-slate-600 leading-relaxed font-outfit max-w-3xl">{teaser}</p>
      </header>

      <!-- Quick Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-20">
        <div class="glass p-6 rounded-2xl border-b-4 border-blue-500">
          <div class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-1">Availability</div>
          <div class="text-2xl font-bold text-slate-900">99.9%</div>
        </div>
        <div class="glass p-6 rounded-2xl border-b-4 border-orange-500">
          <div class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-1">Runtimes</div>
          <div class="text-2xl font-bold text-slate-900">Multi-Plane</div>
        </div>
        <div class="glass p-6 rounded-2xl border-b-4 border-green-500">
          <div class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-1">Latency</div>
          <div class="text-2xl font-bold text-slate-900">&lt;50ms</div>
        </div>
        <div class="glass p-6 rounded-2xl border-b-4 border-purple-500">
          <div class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-1">Parity</div>
          <div class="text-2xl font-bold text-slate-900">100%</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-20">
          
          <!-- Context & Problem -->
          <section>
            <h2 class="text-sm uppercase tracking-widest font-bold text-slate-400 mb-8 flex items-center gap-2">
              <span class="w-8 h-[1px] bg-slate-200"></span> Context & Problem
            </h2>
            <div class="space-y-6 text-lg text-slate-600 leading-relaxed font-outfit">
              <p>
                The enterprise faced a dual challenge: the need for <span class="text-slate-900 font-semibold underline decoration-accent/30">public cloud agility</span> for consumer-facing apps, versus strict <span class="text-slate-900 font-semibold underline decoration-accent/30">data residency</span> and low-latency requirements for core mainframe systems.
              </p>
              <div class="bg-blue-50/50 border-l-4 border-blue-500 p-6 rounded-r-xl">
                <h4 class="text-blue-800 font-bold mb-2">The Solution</h4>
                <p class="text-blue-700/80 text-sm italic">A unified hybrid platform that steers traffic across planes seamlessly, ensuring every workload sits exactly where it belongs—cloud or datacenter—without siloed management.</p>
              </div>
            </div>
          </section>

          <!-- The Hybrid Architecture -->
          <section>
            <h2 class="text-sm uppercase tracking-widest font-bold text-slate-400 mb-8 flex items-center gap-2">
              <span class="w-8 h-[1px] bg-slate-200"></span> Platform Topology
            </h2>
            <div class="mb-4">
              <div class="glass p-2 md:p-4 rounded-[2.5rem] bg-slate-50/50 overflow-hidden group cursor-zoom-in" data-zoom-trigger>
                <div class="relative overflow-hidden rounded-[2rem]">
                  <img 
                    src="/images/hybrid-mulesoft-rtf-topology.png" 
                    alt="Hybrid MuleSoft RTF Topology" 
                    class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
                    data-gsap="reveal"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                </div>
              </div>
            </div>
          </section>

          <!-- Technical Deep Dive Sections -->
          <div class="space-y-16 pt-8">
            <section>
              <h3 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight">Networking & Ingress</h3>
              <p class="text-slate-600 mb-6 leading-relaxed">
                A centralized F5 Big-IP layer handles environment-wide ingress. By using L7 SNI-based routing, we ensure that external consumer traffic is steered to CloudHub 2.0 Experience APIs, while sensitive internal orchestration requests are sent directly to the RTF cluster on OpenShift.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-5 glass rounded-xl">
                  <div class="font-bold text-slate-900 mb-2 text-sm">TLS Posture</div>
                  <p class="text-slate-500 text-xs">F5 terminates public TLS, re-encrypting to mTLS for all cross-plane communication between CH 2.0 and RTF.</p>
                </div>
                <div class="p-5 glass rounded-xl">
                  <div class="font-bold text-slate-900 mb-2 text-sm">DNS Strategy</div>
                  <p class="text-slate-500 text-xs">Unified <code>api.domain.com</code> namespace with path-based steering to runtime planes.</p>
                </div>
              </div>
            </section>

            <section>
              <h3 class="text-2xl font-bold text-slate-900 mb-6 tracking-tight">OpenShift & RTF Ops</h3>
              <p class="text-slate-600 mb-6 leading-relaxed">
                RTF on OpenShift provides a containerized runtime within the datacenter. This architecture defers infrastructure management to the OpenShift operator while giving MuleSoft precise control over CPU/Memory isolation for mission-critical core banking services.
              </p>
              <ul class="space-y-4">
                {[
                  { t: "Environment Parity", d: "Identical RTF clusters in DEV/TST/STG/PRD to ensure testing validity." },
                  { t: "RPO/RTO Targets", d: "Architected for 1-hour RTO using automated F5 DNS cutovers." }
                ].map(item => (
                  <li class="flex gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-accent mt-2 flex-shrink-0"></div>
                    <div>
                      <span class="font-bold text-slate-900 text-sm block">{item.t}</span>
                      <span class="text-slate-500 text-sm">{item.d}</span>
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          </div>

          <!-- Retrospective -->
          <section>
             <div class="bg-slate-900 rounded-[2.5rem] p-10 text-white relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                  <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-6 flex items-center gap-3">
                   <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-blue-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
                   </div>
                   Executive Retrospective
                </h3>
                <p class="text-slate-300 text-lg leading-relaxed italic font-outfit">
                   "The biggest challenge wasn't the hybrid runtime—it was the initial firewall friction. If I could redo the pilot, I'd insist on a pre-approved 'Platform Wide' CIDR allow-list for CH 2.0 to RTF traffic. We spent weeks debugging individual micro-segmentation rules that could have been handled as a single infrastructure trust zone."
                </p>
             </div>
          </section>

        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-4 space-y-12">
          
          <!-- Personally Owned -->
          <div class="glass p-8 rounded-3xl border-l-4 border-accent">
            <h3 class="text-slate-900 font-bold mb-6">What I Personally Owned</h3>
            <ul class="space-y-4">
              {[
                "Hybrid Platform Blueprint",
                "F5 Ingress Policy Design",
                "RTF on OpenShift Integration",
                "mTLS Cross-Plane Security",
                "Automated DR Runbooks"
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-accent mt-0.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  <span class="text-slate-600 text-sm font-semibold">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Tooling -->
          <div>
            <h3 class="text-sm uppercase tracking-widest font-bold text-slate-400 mb-6">Technologies</h3>
            <div class="flex flex-wrap gap-2">
              {["CloudHub 2.0", "RTF", "OpenShift", "F5 Big-IP", "mTLS", "Anypoint MQ", "Terraform"].map(tech => (
                <span class="px-3 py-1.5 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider rounded-lg border border-slate-200">{tech}</span>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <div class="bg-accent/5 border border-accent/10 p-8 rounded-3xl text-center">
            <div class="w-12 h-12 bg-accent/20 rounded-2xl flex items-center justify-center text-accent mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            </div>
            <h4 class="text-slate-900 font-bold mb-2 text-sm">Technical Deep-Dive</h4>
            <p class="text-slate-500 text-xs mb-6">Download the 40-page reference architecture PDF.</p>
            <button class="w-full py-4 bg-accent text-white text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-accent-muted transition-colors shadow-lg shadow-accent/20 cursor-not-allowed opacity-50">
              Download Coming Soon
            </button>
          </div>

        </div>
      </div>
    </div>
  </article>

  <!-- Image Zoom Overlay -->
  <div id="zoom-overlay" class="fixed inset-0 z-[100] bg-slate-900/98 backdrop-blur-2xl hidden flex items-center justify-center cursor-zoom-out p-4 md:p-12 transition-all duration-500">
      <div class="relative w-full h-full flex items-center justify-center">
          <img id="zoom-image" src="" alt="Zoomed Diagram" class="max-w-full max-h-full object-contain rounded-xl shadow-2xl border border-white/10" />
          <button id="close-zoom" class="absolute top-4 right-4 md:top-8 md:right-8 p-3 bg-white/10 hover:bg-white/20 hover:scale-110 active:scale-90 rounded-full text-white transition-all duration-300" aria-label="Close zoom">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
          
          <div class="absolute bottom-8 left-1/2 -translate-x-1/2 bg-white/10 backdrop-blur-md px-6 py-2 rounded-full border border-white/20 text-white/70 text-[10px] font-bold uppercase tracking-widest pointer-events-none">
            Click anywhere to close
          </div>
      </div>
  </div>

  <script>
      import { gsap } from 'gsap';

      document.addEventListener('DOMContentLoaded', () => {
          const trigger = document.querySelector('[data-zoom-trigger]');
          const overlay = document.getElementById('zoom-overlay');
          const zoomImg = document.getElementById('zoom-image') as HTMLImageElement;
          const closeBtn = document.getElementById('close-zoom');

          if (!trigger || !overlay || !zoomImg) return;

          trigger.addEventListener('click', () => {
              const img = trigger.querySelector('img');
              if (!img) return;
              
              zoomImg.src = img.src;
              
              overlay.classList.remove('hidden');
              
              // GSAP Animation for premium feel
              gsap.fromTo(overlay, 
                  { opacity: 0 }, 
                  { opacity: 1, duration: 0.5, ease: "power3.out" }
              );
              
              gsap.fromTo(zoomImg, 
                  { scale: 0.9, opacity: 0, y: 20 }, 
                  { scale: 1, opacity: 1, y: 0, duration: 0.7, ease: "expo.out", delay: 0.1 }
              );
              
              document.body.style.overflow = 'hidden'; // Prevent background scroll
          });

          const closeZoom = () => {
              gsap.to(overlay, { 
                  opacity: 0, 
                  duration: 0.4, 
                  ease: "power3.inOut",
                  onComplete: () => {
                      overlay.classList.add('hidden');
                      document.body.style.overflow = '';
                  }
              });
          };

          overlay.addEventListener('click', closeZoom);
          closeBtn?.addEventListener('click', (e) => {
              e.stopPropagation();
              closeZoom();
          });
          
          // Escape key to close
          document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && !overlay.classList.contains('hidden')) {
                  closeZoom();
              }
          });
      });
  </script>
</BaseLayout>
