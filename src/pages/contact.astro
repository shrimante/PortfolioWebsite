---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const contactReasons = [
  { id: 'hiring', label: 'Hiring / Roles', icon: 'briefcase' },
  { id: 'consulting', label: 'Strategic Consulting', icon: 'trending-up' },
  { id: 'speaking', label: 'Speaking / Workshops', icon: 'mic' },
  { id: 'other', label: 'Other Inquiry', icon: 'message-circle' }
];
---

<BaseLayout title="Contact & Strategy | Sriman Tirupathy Eshwarappa">
  <section class="pt-32 pb-24">
    <div class="container mx-auto px-6 max-w-5xl">
      
      <header class="mb-20 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-[10px] font-bold tracking-widest text-accent uppercase bg-accent/5 rounded-full border border-accent/10">
          Start a Conversation
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tighter italic">Talk Integration <span class="text-accent underline decoration-slate-200">Strategy</span></h1>
        <p class="text-xl text-slate-600 leading-relaxed font-outfit max-w-2xl mx-auto">
          Currently open to discussing architecture leadership, platform modernizations, or strategic consulting engagements.
        </p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        
        <!-- Left: Scheduling -->
        <div class="lg:col-span-5 space-y-12">
          <div class="glass p-10 rounded-3xl bg-slate-900 text-white relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </div>
            
            <h2 class="text-2xl font-bold mb-6 tracking-tight">Schedule a Call</h2>
            <p class="text-slate-400 mb-10 font-outfit leading-relaxed">
              Skip the back-and-forth. Book a 15-minute introductory call to discuss your integration roadmap or leadership needs.
            </p>
            
            <a href="https://calendly.com/sriman-arch/15min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-full py-4 bg-accent text-white text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-accent-muted transition-all shadow-xl shadow-accent/20">
              Open Calendly Scheduler
            </a>
            
            <div class="mt-8 pt-8 border-t border-white/10 flex items-center justify-between text-[10px] uppercase font-bold tracking-widest text-slate-500">
               <span>Availability: Dubai / IST / UTC</span>
               <span class="text-green-500 flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                Active
               </span>
            </div>
          </div>

          <div class="space-y-8 px-4">
            <h3 class="text-sm font-bold uppercase tracking-widest text-slate-400">Direct Channels</h3>
            <div class="space-y-6">
              <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-4 group">
                <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center text-slate-400 group-hover:text-accent group-hover:border-accent transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <div>
                  <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Email</div>
                  <div class="text-slate-900 font-bold group-hover:text-accent transition-colors">{siteConfig.email}</div>
                </div>
              </a>
              <a href={siteConfig.linkedIn} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
                <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center text-slate-400 group-hover:text-accent group-hover:border-accent transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                </div>
                <div>
                  <div class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">LinkedIn</div>
                  <div class="text-slate-900 font-bold group-hover:text-accent transition-colors">Professional Network</div>
                </div>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Inquiry Form -->
        <div class="lg:col-span-7">
          <div class="glass p-12 rounded-[2.5rem] border border-slate-200 bg-white/50 relative">
            <h2 class="text-2xl font-bold text-slate-900 mb-8 tracking-tight">Send an Inquiry</h2>
            
            <form action="/api/contact" method="POST" class="space-y-8">
              <!-- Reason Selection -->
              <div class="space-y-4">
                <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block">Reason for Contact</label>
                <div class="grid grid-cols-2 gap-3">
                  {contactReasons.map(reason => (
                    <label class="relative cursor-pointer group">
                      <input type="radio" name="reason" value={reason.id} class="peer sr-only" required />
                      <div class="p-4 bg-white border border-slate-200 rounded-xl text-center transition-all peer-checked:border-accent peer-checked:bg-accent/5 hover:border-accent/50 group-active:scale-[0.98]">
                        <div class="text-xs font-bold text-slate-700 peer-checked:text-accent">{reason.label}</div>
                      </div>
                    </label>
                  ))}
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-3">
                  <label for="name" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block">Full Name</label>
                  <input type="text" id="name" name="name" required class="w-full p-4 bg-white border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all font-outfit" />
                </div>
                <div class="space-y-3">
                  <label for="email" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block">Professional Email</label>
                  <input type="email" id="email" name="email" required class="w-full p-4 bg-white border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all font-outfit" />
                </div>
              </div>

              <div class="space-y-3">
                <label for="company" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block">Company / Role</label>
                <input type="text" id="company" name="company" required class="w-full p-4 bg-white border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all font-outfit" />
              </div>

              <div class="space-y-3">
                <label for="message" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block">Message</label>
                <textarea id="message" name="message" rows="5" required class="w-full p-4 bg-white border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all font-outfit resize-none" placeholder="How can I help with your integration program?"></textarea>
              </div>

              <button type="submit" class="w-full py-5 bg-slate-900 text-white font-bold rounded-xl hover:bg-slate-800 transition-all shadow-xl shadow-slate-900/10 text-[10px] uppercase tracking-widest">
                Send Message
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
